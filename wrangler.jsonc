{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "sage-import",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-13",
  "routes": [
    {
      "pattern": "sage-import.27tools.co/*",
      "zone_name": "27tools.co"
    }
  ],
  "observability": {
    "enabled": true
  }
}
